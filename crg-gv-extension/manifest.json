{
  "manifest_version": 3,
  "name": "CRG Google Voice Helper",
  "version": "1.0.1",
  "description": "Auto-fills phone number and message in Google Voice when sending texts from CRG Houston.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://voice.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://crghouston.org/*",
      "https://www.crghouston.org/*",
      "http://localhost:*/*"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
